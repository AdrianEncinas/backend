# Database
POSTGRES_DB=investdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/investdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Security
JWT_SECRET=change-this-jwt-secret-in-production
JWT_EXPIRATION=86400000

# JPA
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# Azure passwordless integration (set true only in Azure)
AZURE_MANAGED_IDENTITY_ENABLED=false
SPRING_DATASOURCE_AZURE_PASSWORDLESS_ENABLED=false

# Optional JVM settings
JAVA_OPTS=-Xms256m -Xmx512m
